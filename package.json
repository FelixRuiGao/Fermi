{
  "name": "fermi-code",
  "version": "0.3.13",
  "updateNotice": "",
  "description": "A terminal AI coding agent built for long sessions — three-layer context management, persistent memory, and parallel sub-agents",
  "type": "module",
  "license": "MIT",
  "author": "Felix Rui Gao",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FelixRuiGao/Fermi.git"
  },
  "homepage": "https://github.com/FelixRuiGao/Fermi",
  "bugs": {
    "url": "https://github.com/FelixRuiGao/Fermi/issues"
  },
  "workspaces": [
    "opentui-src/forked/core"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "coding-agent",
    "multi-agent",
    "context-management",
    "summarization",
    "terminal"
  ],
  "scripts": {
    "build": "bun run scripts/build-binary.ts",
    "dev": "bun run opentui-src/main.tsx",
    "dev:cli": "bun src/cli.ts",
    "opentui:dev": "bun run opentui-src/main.tsx",
    "test": "bun test tests/ opentui-src/transcript/ opentui-src/components/",
    "test:watch": "bun test --watch tests/ opentui-src/transcript/ opentui-src/components/",
    "typecheck": "tsc --noEmit",
    "docs:dev": "npm --prefix docs-site run dev",
    "docs:build": "npm --prefix docs-site install && npm --prefix docs-site run build"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@inquirer/prompts": "^8.3.0",
    "@joplin/turndown-plugin-gfm": "^1.0.67",
    "@mozilla/readability": "^0.6.0",
    "@opentui/core": "workspace:*",
    "@opentui/react": "0.4.1",
    "@xmldom/xmldom": "^0.9.10",
    "bun-ffi-structs": "0.2.3",
    "commander": "^12.0.0",
    "diff": "^9.0.0",
    "gpt-tokenizer": "^3.4.0",
    "jimp": "^1.6.0",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.12.0",
    "marked": "^17.0.0",
    "marked-terminal": "^7.0.0",
    "openai": "^4.90.0",
    "react": "^19.2.4",
    "shiki": "^4.0.2",
    "string-width": "7.2.0",
    "strip-ansi": "^7.1.0",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-powershell": "^0.26.4",
    "turndown": "^7.2.4",
    "unpdf": "^1.6.2",
    "web-tree-sitter": "0.25.10"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@opentui/core-darwin-arm64": "0.4.1",
    "@opentui/core-linux-arm64": "0.4.1",
    "@opentui/core-linux-x64": "0.4.1",
    "@opentui/core-win32-arm64": "0.4.1",
    "@opentui/core-win32-x64": "0.4.1"
  },
  "overrides": {
    "@opentui/core": "workspace:*"
  }
}
