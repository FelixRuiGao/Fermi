---
const base = import.meta.env.BASE_URL;
const enHref = base + "blog/";
const posts = [
  { date: "2026 年 6 月 5 日", title: "单 Agent 就够了", href: base + "zh/blog/one-agent-is-enough/", desc: "为什么单执行者 + 干净上下文的辅助 Agent 胜过多 Agent 协作——至少现在是这样。" },
  { date: "2026 年 5 月 29 日", title: "与 Fermi 对话的正确方式", href: base + "zh/blog/how-to-talk-to-fermi/", desc: "与 Coding Agent 协作时真正有用的三个沟通技巧。" },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>博客 — Fermi</title>
  <link rel="preload" href={base + "fonts/instrument-serif-400-normal-latin.woff2"} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={base + "fonts/instrument-serif-400-italic-latin.woff2"} as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href={base + "fonts/fonts.css"} />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0a0c11; color: #e8ecf2; font-family: "Source Serif 4", "Noto Serif SC", serif;
    }
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 6;
      display: flex; align-items: center; justify-content: space-between; padding: 22px 36px;
      background: rgba(10,12,17,.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    }
    .wordmark {
      font-family: "Instrument Serif", serif; font-style: italic;
      font-size: 30px; color: #f4f6fa; text-decoration: none; line-height: 1;
    }
    .navlinks { display: flex; gap: 32px; align-items: center; }
    .navlinks a {
      font-family: "JetBrains Mono", monospace; font-size: 13px; color: #aeb6c1;
      text-decoration: none; transition: color .2s;
    }
    .navlinks a:hover { color: #f4f6fa; }
    .langswitch {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: "JetBrains Mono", monospace; font-size: 12px; color: #80838a;
    }
    .langswitch a { font-size: inherit; color: #80838a; }
    .langswitch a.active { color: #8ab4f8; }
    main {
      max-width: 680px; margin: 0 auto; padding: 140px 24px 100px;
    }
    .eyebrow {
      font-family: "JetBrains Mono", monospace; font-size: 13px; letter-spacing: 0.14em;
      text-transform: uppercase; color: #8ab4f8; margin-bottom: 20px;
    }
    h1 {
      font-family: "Instrument Serif", "Noto Serif SC", serif; font-weight: 400; font-size: 48px;
      letter-spacing: 0; color: #f4f6fa; margin-bottom: 48px;
    }
    .post-list { list-style: none; }
    .post-item { border-top: 1px solid #1a1d24; padding: 28px 0; }
    .post-date {
      font-family: "JetBrains Mono", monospace; font-size: 13px; color: #6b7280;
      margin-bottom: 8px; letter-spacing: 0.02em;
    }
    .post-title {
      font-family: "Instrument Serif", "Noto Serif SC", serif; font-weight: 400; font-size: 28px;
      color: #f4f6fa; text-decoration: none; line-height: 1.25;
      transition: color .2s;
    }
    .post-title:hover { color: #8ab4f8; }
    .post-desc {
      color: #9ca3af; font-size: 16px; margin-top: 8px; line-height: 1.5;
    }
    @media (max-width: 30rem) {
      .topbar { padding: 22px 20px; }
      .navlinks { gap: 18px; }
      .navlinks > a:nth-child(-n + 1) { display: none; }
      h1 { font-size: 36px; }
      main { padding: 120px 18px 60px; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <a class="wordmark" href={base + "zh/"}>Fermi</a>
    <nav class="navlinks">
      <a href={base + "zh/getting-started/"}>文档</a>
      <a href={base + "zh/blog/"}>博客</a>
      <a href="https://github.com/FelixRuiGao/Fermi">GitHub ↗</a>
      <span class="langswitch" aria-label="语言切换">
        <a href={enHref} data-lang-link="en" lang="en">EN</a>
        <span aria-hidden="true">/</span>
        <a class="active" href={base + "zh/blog/"} data-lang-link="zh" lang="zh-CN">中文</a>
      </span>
    </nav>
  </header>
  <main>
    <div class="eyebrow">// 博客</div>
    <h1>博客</h1>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <div class="post-date">{post.date}</div>
          <a class="post-title" href={post.href}>{post.title}</a>
          <p class="post-desc">{post.desc}</p>
        </li>
      ))}
    </ul>
  </main>
  <script is:inline>
    const LANG_PREF_KEY = 'fermi-docs-lang';
    document.querySelectorAll('[data-lang-link]').forEach((link) => {
      link.addEventListener('click', () => {
        localStorage.setItem(LANG_PREF_KEY, link.getAttribute('data-lang-link'));
      });
    });
  </script>
</body>
</html>
