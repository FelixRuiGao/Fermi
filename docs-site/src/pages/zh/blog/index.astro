---
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>博客 — Fermi</title>
  <link rel="preload" href={base + "fonts/instrument-serif-400-normal-latin.woff2"} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={base + "fonts/instrument-serif-400-italic-latin.woff2"} as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href={base + "fonts/fonts.css"} />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      background: #0a0c11; color: #e8ecf2; font-family: "Source Serif 4", "Noto Serif SC", serif;
    }
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 6;
      display: flex; align-items: center; justify-content: space-between; padding: 22px 36px;
    }
    .wordmark {
      font-family: "Instrument Serif", serif; font-style: italic;
      font-size: 30px; color: #f4f6fa; text-decoration: none; line-height: 1;
    }
    .navlinks { display: flex; gap: 32px; align-items: center; }
    .navlinks a {
      font-family: "JetBrains Mono", monospace; font-size: 13px; color: #aeb6c1;
      text-decoration: none; transition: color .2s;
    }
    .navlinks a:hover { color: #f4f6fa; }
    .langswitch {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: "JetBrains Mono", monospace; font-size: 12px; color: #80838a;
    }
    .langswitch a { font-size: inherit; color: #80838a; }
    .langswitch a.active { color: #8ab4f8; }
    main {
      min-height: 100%; display: flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center; padding: 0 24px;
    }
    .eyebrow {
      font-family: "JetBrains Mono", monospace; font-size: 13px; letter-spacing: 0.14em;
      text-transform: uppercase; color: #8ab4f8; margin-bottom: 20px;
    }
    h1 {
      font-family: "Instrument Serif", "Noto Serif SC", serif; font-weight: 400; font-size: 64px;
      letter-spacing: 0; color: #f4f6fa; margin-bottom: 14px;
    }
    p { color: #aeb6c1; font-size: 18px; }
    @media (max-width: 30rem) {
      .topbar { padding: 22px 28px; }
      .navlinks { gap: 18px; }
      .navlinks > a:nth-child(-n + 2) { display: none; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <a class="wordmark" href={base + "zh/"}>Fermi</a>
    <nav class="navlinks">
      <a href={base + "zh/getting-started/"}>文档</a>
      <a href={base + "zh/blog/"}>博客</a>
      <a href="https://github.com/FelixRuiGao/Fermi">GitHub ↗</a>
      <span class="langswitch" aria-label="语言切换">
        <a href={base + "blog/"} data-lang-link="en" lang="en">EN</a>
        <span aria-hidden="true">/</span>
        <a class="active" href={base + "zh/blog/"} data-lang-link="zh" lang="zh-CN">中文</a>
      </span>
    </nav>
  </header>
  <main>
    <div class="eyebrow">// 博客</div>
    <h1>即将上线。</h1>
    <p>文章正在准备中，请稍后再回来看看。</p>
  </main>
  <script is:inline>
    const LANG_PREF_KEY = 'fermi-docs-lang';
    document.querySelectorAll('[data-lang-link]').forEach((link) => {
      link.addEventListener('click', () => {
        localStorage.setItem(LANG_PREF_KEY, link.getAttribute('data-lang-link'));
      });
    });
  </script>
</body>
</html>
