---
const base = import.meta.env.BASE_URL; // "/Fermi/"
const docsHref = base + "getting-started/";
const blogHref = base + "blog/";
const githubHref = "https://github.com/FelixRuiGao/Fermi";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fermi — the coding agent that manages its own contexts</title>
  <meta name="description" content="A terminal AI coding agent with surgical context management for multi-hour sessions." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      background: #0a0c11;
      color: #e8ecf2;
      font-family: "Source Serif 4", serif;
      overflow: hidden;
    }
    #stage { position: fixed; inset: 0; }
    canvas { position: absolute; inset: 0; display: block; }

    /* Top bar */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 6;
      display: flex; align-items: center; justify-content: space-between;
      padding: 22px 36px;
    }
    .wordmark {
      font-family: "Instrument Serif", serif; font-style: italic;
      font-size: 30px; color: #f4f6fa; text-decoration: none; line-height: 1;
    }
    .navlinks { display: flex; gap: 32px; align-items: center; }
    .navlinks a {
      font-family: "JetBrains Mono", monospace; font-size: 13px; font-weight: 400;
      color: #aeb6c1; text-decoration: none; letter-spacing: 0.01em; transition: color .2s;
    }
    .navlinks a:hover { color: #f4f6fa; }

    /* Hero */
    .hero {
      position: relative; z-index: 2; height: 100%;
      display: flex; flex-direction: column; justify-content: center;
      padding: 0 9vw;
    }
    .eyebrow {
      font-family: "JetBrains Mono", monospace; font-size: 13px; letter-spacing: 0.14em;
      text-transform: uppercase; color: #8ab4f8; margin-bottom: 26px; opacity: 0.9;
    }
    h1 {
      font-family: "Instrument Serif", serif; font-weight: 400;
      font-size: 92px; line-height: 0.95; letter-spacing: -0.03em;
      color: #f4f6fa; margin-bottom: 28px;
    }
    h1 .it { font-style: italic; color: #8ab4f8; }
    .tagline {
      font-size: 19px; line-height: 1.5; max-width: 30em; color: #aeb6c1; margin-bottom: 40px;
    }

    /* Install command box */
    .install {
      display: inline-flex; align-items: center;
      background: #15171c; border: 1px solid #23262d; border-radius: 11px;
      padding: 6px; position: relative; width: min(560px, 80vw);
    }
    .os-pill {
      display: inline-flex; align-items: center; gap: 8px; flex-shrink: 0;
      background: #e8ecf2; color: #15171c; border: none; border-radius: 7px;
      font-family: "JetBrains Mono", monospace; font-size: 13px; font-weight: 500;
      padding: 9px 13px; cursor: pointer; transition: background .15s;
    }
    .os-pill:hover { background: #fff; }
    .os-pill .caret { width: 11px; height: 11px; opacity: 0.7; }
    .cmd {
      font-family: "JetBrains Mono", monospace; font-size: 13px; color: #aeb6c1;
      padding: 0 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      flex: 1; min-width: 0;
    }
    .cmd .tok { color: #8ab4f8; }
    .copy {
      flex-shrink: 0; background: none; border: none; cursor: pointer;
      color: #80838a; padding: 8px; border-radius: 6px; display: inline-flex;
      transition: color .15s, background .15s;
    }
    .copy:hover { color: #e8ecf2; background: #1c1f25; }
    .copy svg { width: 16px; height: 16px; }
    .os-menu {
      position: absolute; top: calc(100% + 8px); left: 0;
      background: #16181d; border: 1px solid #2a2d34; border-radius: 9px;
      padding: 5px; min-width: 170px; z-index: 10; display: none;
      box-shadow: 0 12px 36px rgba(0,0,0,0.5);
    }
    .os-menu.open { display: block; }
    .os-menu button {
      display: flex; align-items: center; gap: 9px; width: 100%; text-align: left;
      background: none; border: none; color: #cdd2dc;
      font-family: "JetBrains Mono", monospace; font-size: 13px;
      padding: 9px 11px; border-radius: 6px; cursor: pointer; transition: background .12s;
    }
    .os-menu button:hover { background: #23262d; }
    .os-menu button.active { color: #8ab4f8; }
  </style>
</head>
<body>
  <div id="stage">
    <canvas id="c"></canvas>

    <header class="topbar">
      <a class="wordmark" href={base}>Fermi</a>
      <nav class="navlinks">
        <a href={docsHref}>Docs</a>
        <a href={blogHref}>Blog</a>
        <a href={githubHref}>GitHub ↗</a>
      </nav>
    </header>

    <div class="hero">
      <div class="eyebrow">// The coding agent</div>
      <h1><span class="it">Context</span> that<br />never resets.</h1>
      <p class="tagline">Fermi manages its own contexts so a single session runs for hours — no blind resets, no lost decisions.</p>

      <div class="install" id="install">
        <button class="os-pill" id="osPill" aria-haspopup="true" aria-expanded="false">
          <span id="osLabel">Install for macOS / Linux</span>
          <svg class="caret" viewBox="0 0 16 8" fill="none" aria-hidden="true"><path d="M1 1l7 6 7-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <code class="cmd" id="cmd"></code>
        <button class="copy" id="copyBtn" title="Copy command" aria-label="Copy command">
          <svg id="copyIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
        </button>
        <div class="os-menu" id="osMenu" role="menu">
          <button data-os="unix" role="menuitem">macOS / Linux</button>
          <button data-os="win" role="menuitem">Windows</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    /* Static dot field */
    const canvas = document.getElementById('c');
    const ctx = canvas.getContext('2d');
    let W, H, DPR, dots = [];
    const SPACING = 30;
    function buildGrid() {
      dots = [];
      const cols = Math.ceil(W / SPACING) + 1, rows = Math.ceil(H / SPACING) + 1;
      for (let r = 0; r < rows; r++)
        for (let c = 0; c < cols; c++)
          dots.push({ x: c * SPACING, y: r * SPACING });
    }
    function render() {
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = 'rgba(138,180,248,0.15)';
      for (const d of dots) { ctx.beginPath(); ctx.arc(d.x, d.y, 1.3, 0, Math.PI * 2); ctx.fill(); }
    }
    function resize() {
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      W = window.innerWidth; H = window.innerHeight;
      canvas.width = W * DPR; canvas.height = H * DPR;
      canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      buildGrid(); render();
    }
    window.addEventListener('resize', resize);
    resize();

    /* Install command, OS-aware */
    const CMD = {
      unix: 'curl -fsSL https://raw.githubusercontent.com/FelixRuiGao/Fermi/main/scripts/install.sh | sh',
      win:  'irm https://raw.githubusercontent.com/FelixRuiGao/Fermi/main/scripts/install.ps1 | iex',
    };
    const LABEL = { unix: 'Install for macOS / Linux', win: 'Install for Windows' };
    function detectOS() {
      const ua = navigator.userAgent, p = navigator.platform || '';
      if (/Win/i.test(p) || /Windows/i.test(ua)) return 'win';
      return 'unix';
    }
    const osLabel = document.getElementById('osLabel');
    const cmdEl = document.getElementById('cmd');
    const osMenu = document.getElementById('osMenu');
    const osPill = document.getElementById('osPill');
    const copyBtn = document.getElementById('copyBtn');
    const copyIcon = document.getElementById('copyIcon');
    let currentOS = detectOS();
    function setOS(os) {
      currentOS = os;
      osLabel.textContent = LABEL[os];
      const cmd = CMD[os];
      const sp = cmd.indexOf(' ');
      cmdEl.innerHTML = '<span class="tok">' + cmd.slice(0, sp) + '</span>' + cmd.slice(sp);
      for (const b of osMenu.querySelectorAll('button'))
        b.classList.toggle('active', b.dataset.os === os);
    }
    setOS(currentOS);
    osPill.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = osMenu.classList.toggle('open');
      osPill.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    osMenu.querySelectorAll('button').forEach((b) =>
      b.addEventListener('click', () => { setOS(b.dataset.os); osMenu.classList.remove('open'); })
    );
    document.addEventListener('click', () => osMenu.classList.remove('open'));
    const COPY_PATH = '<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/>';
    const CHECK_PATH = '<path d="M20 6L9 17l-5-5"/>';
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(CMD[currentOS]);
        copyIcon.innerHTML = CHECK_PATH;
        copyBtn.style.color = '#8ab4f8';
        setTimeout(() => { copyIcon.innerHTML = COPY_PATH; copyBtn.style.color = ''; }, 1500);
      } catch (e) {}
    });
  </script>
</body>
</html>
